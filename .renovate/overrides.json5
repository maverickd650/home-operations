{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Keep CloudNativePG individual images on the correct minimal-trixie series",
      "matchPackageNames": ["ghcr.io/cloudnative-pg/postgresql"],
      "separateMajorMinor": true,
      "major": {
        "enabled": false
      }
    },
    {
      "description": "Block Rancher shell 7.x",
      "matchPackageNames": ["docker.io/rancher/shell"],
      "matchDatasources": ["docker"],
      "allowedVersions": "<7.0.0"
    }
  ]
}
