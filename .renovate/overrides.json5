{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Override Helmfile Dependency Name",
      "matchDatasources": ["docker"],
      "matchManagers": ["helmfile"],
      "overrideDepName": "{{packageName}}"
    },
    {
      "description": "Keep CloudNativePG individual images on the correct minimal-trixie series",
      "matchPackageNames": ["ghcr.io/cloudnative-pg/postgresql"],
      "separateMajorMinor": true,
      "major": {
        "enabled": false
      }
    },
    {
      "description": "Ignore duff Rancher shell image",
      "matchPackageNames": ["docker.io/rancher/shell"],
      "matchDatasources": ["docker"],
      "ignoreVersions": ["v7.0.0"]
    }
  ]
}
