{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    'github>MaverickD650/home-operations//.renovate/autoMerge.json5',
    'github>MaverickD650/home-operations//.renovate/changelogs.json5',
    'github>MaverickD650/home-operations//.renovate/customManagers.json5',
    'github>MaverickD650/home-operations//.renovate/grafanaDashboards.json5',
    'github>MaverickD650/home-operations//.renovate/groups.json5',
    'github>MaverickD650/home-operations//.renovate/labels.json5',
    'github>MaverickD650/home-operations//.renovate/overrides.json5',
    'github>MaverickD650/home-operations//.renovate/semanticCommits.json5',
    'github>MaverickD650/home-operations//.renovate/talosFactory.json5',
    'github>MaverickD650/home-operations//.renovate/upgradeBlock.json5',
    ':automergeBranch',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':timezone(Europe/London)',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  ignorePaths: [
    "**/resources/**",
  ],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
